# 复制本文件为 .env 并填入真实配置后启动服务
# cp .env.example .env

# ==================== 阿里云百炼 ====================
# 控制台申请：https://bailian.console.aliyun.com/ → API-KEY 管理
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 生成回答的主模型 / 多轮改写的小模型 / 向量化 / 重排
LLM_MODEL=qwen-plus
REWRITE_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v3
RERANK_MODEL=gte-rerank-v2

# ==================== JWT（与 Java 端 application.yml 的 jwt.secret 保持一致） ====================
JWT_SECRET=your-jwt-secret-same-as-java
JWT_TOKEN_HEAD=Bearer

# ==================== MySQL（复用 Java 端实例） ====================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=hospital

# ==================== Redis（复用 Java 端实例，db2 与 Java 端 db1 数据隔离） ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=2

# ==================== Langfuse LLM 可观测（可选，不配则自动关闭） ====================
# 注册免费账号：https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ==================== 服务配置 ====================
SERVICE_PORT=8000
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
